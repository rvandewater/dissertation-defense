@article{duncanWirelessMonitoringRealtime2020,
  title = {Wireless Monitoring and Real-Time Adaptive Predictive Indicator of Deterioration},
  author = {Duncan, Heather P. and Fule, Balazs and Rice, Iain and Sitch, Alice J. and Lowe, David},
  date = {2020-07-09},
  journaltitle = {Scientific Reports},
