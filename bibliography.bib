  title = {Using {{Continuous Vital Sign Monitoring}} to {{Detect Early Deterioration}} in {{Adult Postoperative Inpatients}}},
  author = {Verrillo, Sue Carol and Cvach, Maria and Hudson, Krysia Warren and Winters, Bradford D.},
  date = {2019},
