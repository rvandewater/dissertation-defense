@article{lauritsenExplainableArtificialIntelligence2020,
  title = {Explainable Artificial Intelligence Model to Predict Acute Critical Illness from Electronic Health Records},
  author = {Lauritsen, Simon Meyer and Kristensen, Mads and Olsen, Mathias Vassard and Larsen, Morten Skaarup and Lauritsen, Katrine Meyer and Jørgensen, Marianne Johansson and Lange, Jeppe and Thiesson, Bo},
  date = {2020-12},
  journaltitle = {Nature Communications},
