@article{vandewaterCombiningHospitalgradeClinical2024,
  title = {Combining {{Hospital-grade Clinical Data}} and {{Wearable Vital Sign Monitoring}} to {{Predict Surgical Complications}}},
  author = {Van de Water, Robin and Winter, Axel and Maurer, Max M. and Treykorn, Felix August and Zuluaga, Daniela and Pfitzner, Bjarne and Sauer, Igor M. and Arnrich, Bert},
  date = {2024-02-16},
  url = {https://openreview.net/forum?id=EzNGSRPGa7&referrer=%5BAuthor%20Console%5D(%2Fgroup%3Fid%3DICLR.cc%2F2024%2FWorkshop%2FTS4H%2FAuthors%23your-submissions)},
  urldate = {2024-03-05},
  abstract = {Access to the right data at the right time is a substantial hurdle for developing effective machine learning (ML) in healthcare. Many hospitals maintain several isolated patient databases, often leading to incomplete datasets that severely impact the clinical usability of ML prediction systems. Moreover, in visceral surgery, postoperative complications often occur in the nursing ward, where real-time monitoring is non-existent. ML-powered predictive systems are increasingly ineffective as they leave the Intensive Care Unit (ICU) due to data shortage. However, the patient is still at risk of various complications. Our work addresses both issues with a framework that combines pre-operative, intra-operative, ICU, and general patient state parameters. We add a high-resolution continuous vital sign measurement modality collected on a non-intrusive hybrid nursing ward. Using the wearable data, we observe improved prediction accuracy for Surgical Site Infection (SSI). Our work suggests a need for hybrid monitoring after a patient’s ICU stay to further ML modeling in clinical settings.},
  langid = {english},
  file = {/Users/robin/Zotero/storage/PUWGL9U4/Water et al_2024_Combining Hospital-grade Clinical Data and Wearable Vital Sign Monitoring to.pdf}
}

