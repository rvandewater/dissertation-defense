@online{yecheTemporalLabelSmoothing2023,
  title = {Temporal {{Label Smoothing}} for {{Early Event Prediction}}},
  author = {Yèche, Hugo and Pace, Alizée and Rätsch, Gunnar and Kuznetsova, Rita},
