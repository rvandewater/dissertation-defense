@inproceedings{huangInterpretableTemporalConvolutional2021,
  title = {An {{Interpretable Temporal Convolutional Network Model}} for {{Acute Kidney Injury Prediction}} in the {{Intensive Care Unit}}},
  booktitle = {2021 {{IEEE International Conference}} on {{Bioinformatics}} and {{Biomedicine}} ({{BIBM}})},
  author = {Huang, Wei and Chen, Yuwen and Wang, Peng and Liu, Xiang and Liu, Shuguang},
