@article{herrettDataResourceProfile2015,
  title = {Data {{Resource Profile}}: {{Clinical Practice Research Datalink}} ({{CPRD}})},
  shorttitle = {Data {{Resource Profile}}},
  author = {Herrett, Emily and Gallagher, Arlene M and Bhaskaran, Krishnan and Forbes, Harriet and Mathur, Rohini and family=Staa, given=Tjeerd, prefix=van, useprefix=true and Smeeth, Liam},
  date = {2015-06-01},
  journaltitle = {International Journal of Epidemiology},
