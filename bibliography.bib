}

@inproceedings{alefsFoundationModelBasedPropensity2025,
  title = {Towards {{Foundation Model-Based Propensity Score Matching}} from {{Electronic Health Records}}},
  author = {Alefs, Katharina and Ibing, Susanne and Rissom, Pia Francesca and Schmid, Jan Carlo and Kwasigroch, Arkadiusz and family=Water, given=Robin, prefix=van de, useprefix=false and Renard, Bernhard Y. and Alleva, Eugenia},
  date = {2025-09-09},
  abstract = {Propensity score matching (PSM) is a widely used method for estimating causal effects from observational data. However, its reliance on expert-curated covariates can be time-consuming and may overlook important patterns in complex longitudinal clinical records. We propose \$\textbackslash textbf\{Embed-PSM\}\$, a novel framework that leverages patient representations from clinical foundation models (FM) pretrained on structured electronic health records (EHR) to estimate propensity scores. By replacing engineered features with FM-derived embeddings, Embed-PSM captures rich temporal and contextual patterns in patient histories while eliminating the need for specific feature design. We evaluate Embed-PSM using real-world EHR data from over 50,000 patients in two large-scale simulated intervention studies with systematically varied confounding scenarios. Across three different FMs, we show that FM-based matching consistently performs comparably to a traditional baseline in recovering treatment effects, reducing bias and balancing patient characteristics. This work introduces the first application of clinical foundation models to PSM and highlights their potential for scalable, representation-driven causal inference.},
  eventtitle = {Machine {{Learning}} for {{Health Symposium}} 2025},
  langid = {english},
  file = {/Users/robin/Zotero/storage/BIIXS8XL/Alefs et al. - 2025 - Towards Foundation Model-Based Propensity Score Matching from Electronic Health Records.pdf}
}

