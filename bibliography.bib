  author = {Katayama, Hiroshi and Kurokawa, Yukinori and Nakamura, Kenichi and Ito, Hiroyuki and Kanemitsu, Yukihide and Masuda, Norikazu and Tsubosa, Yasuhiro and Satoh, Toyomi and Yokomizo, Akira and Fukuda, Haruhiko and Sasako, Mitsuru},
