@article{sadeghiEarlyHospitalMortality2018,
  title = {Early {{Hospital Mortality Prediction}} Using {{Vital Signals}}},
  author = {Sadeghi, Reza and Banerjee, Tanvi and Romine, William},
  date = {2018-12},
  journaltitle = {Smart health (Amsterdam, Netherlands)},
  shortjournal = {Smart Health (Amst)},
