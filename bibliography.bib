@online{wangIntegratingPhysiologicalTime2022,
  title = {Integrating {{Physiological Time Series}} and {{Clinical Notes}} with {{Transformer}} for {{Early Prediction}} of {{Sepsis}}},
  author = {Wang, Yuqing and Zhao, Yun and Callcut, Rachael and Petzold, Linda},
  date = {2022-03-27},
  eprint = {2203.14469},
  eprinttype = {arXiv},
