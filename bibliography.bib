@article{delsoleStateMachineLearning2022,
  type = {Journal article},
  title = {The State of Machine Learning in Spine Surgery: {{A}} Systematic Review.},
  author = {DelSole, Edward M and Keck, Wyatt L and Patel, Aalpen A},
